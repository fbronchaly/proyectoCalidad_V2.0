        { "$group": { "_id": null, "promedio": { "$avg": "$puntuacion" }, "total_tests": { "$sum": 1 } } },
        { "$project": { "_id": 0, "resultado": { "$round": ["$promedio", 2] }, "numero_pacientes": "$total_tests" } }
      ]
    }
  },
