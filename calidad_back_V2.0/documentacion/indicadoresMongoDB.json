[
  {
    "id_code": "MONGO_FRAIL_POSITIVO",
    "categoria": "Valoración Geriátrica - Fragilidad",
    "indicador": "Porcentaje de tests FRAIL con resultado positivo (≥3 puntos) en el periodo",
    "unidad": "%",
    "fuente": "mongodb",
    "template": {
      "collection": "test_responses",
      "pipeline": [
        { "$match": { "metadata.form_id": "frail", "metadata.centro": ":CENTRO", "_isTest": { "$ne": true } } },
        { "$addFields": { "fechaDate": { "$dateFromString": { "dateString": "$metadata.fecha_insercion", "format": "%d-%m-%Y", "onError": null, "onNull": null } } } },
        { "$match": { "fechaDate": { "$gte": { "$toDate": ":FECHAINI" }, "$lte": { "$toDate": ":FECHAFIN" } } } },
        { "$group": { "_id": null, "total_tests": { "$sum": 1 }, "tests_positivos": { "$sum": { "$cond": [{ "$gte": ["$puntuacion", 3] }, 1, 0] } } } },
        { "$project": { "_id": 0, "resultado": { "$multiply": [{ "$divide": ["$tests_positivos", { "$ifNull": ["$total_tests", 1] }] }, 100] }, "numero_pacientes": "$total_tests", "numerador": "$tests_positivos" } }
      ]
    }
  },
  {
    "id_code": "MONGO_FRAIL_MEDIA",
    "categoria": "Valoración Geriátrica - Fragilidad",
    "indicador": "Puntuación media del test FRAIL en el periodo",
    "unidad": "Puntos",
    "fuente": "mongodb",
    "template": {
      "collection": "test_responses",
      "pipeline": [
        { "$match": { "metadata.form_id": "frail", "metadata.centro": ":CENTRO", "_isTest": { "$ne": true } } },
